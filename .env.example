# Global (Docker’da tüm stack için: prod’da production yapın)
NODE_ENV=development
# docker-compose.yml api/worker için RUNNING_IN_DOCKER=true ayarlar; uygulama apps/*/.env dosyaları mevcut olsa bile Compose ortamı önceliklidir.

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ucuzabak
POSTGRES_PASSWORD=ucuzabak
POSTGRES_DB=ucuzabak
DATABASE_URL=postgresql://ucuzabak:ucuzabak@postgres:5432/ucuzabak

# PostgreSQL yedek (API: pg_dump / psql)
# Docker Compose: api hizmetinde BACKUP_DIR=/data/backups (volume api_backups) ve DATABASE_URL içinde host=postgres kullanılır;
# kök .env içinde DATABASE_URL=...@localhost... bıraksanız bile compose ortamı genelde @postgres ile yazar — API’yi konteyner dışında
# çalıştırıyorsanız DATABASE_URL ana makine localhost:5432 olmalıdır.
# Yerel API (pnpm): PostgreSQL kurulumundan pg_dump PATH’te değilse PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe (veya psql için PSQL_PATH)
# BACKUP_DIR=./data/backups
# Manuel feed dosyaları (API yazar, worker okur — Docker’da aynı volume: /data/feed-imports)
# FEED_IMPORT_UPLOAD_DIR=./data/feed-imports
# Anasayfa banner görselleri (API diske yazar; Docker: /data/uploads/banners)
# BANNER_UPLOAD_DIR=./data/uploads/banners
# Büyük yapıştırma gövdesi (Nest JSON limiti, örn. 32mb)
# JSON_BODY_LIMIT_MAX=32mb
# BACKUP_RETENTION_DAYS=14
# BACKUP_AUTO_ENABLED=true
# BACKUP_CRON=0 3 * * *
# Toplu e-posta batch boyutu (API) ve gönderim gecikmesi (worker, ms)
# BULK_EMAIL_BATCH_SIZE=25
# BULK_EMAIL_SEND_DELAY_MS=60
# Günlük kuyruk üst sınırı (alıcı sayısı, UTC günü; varsayılan 10000)
# BULK_EMAIL_MAX_RECIPIENTS_PER_DAY=10000
# Ortam genelinde test: gerçek kullanıcı listesi yerine yalnızca test alıcıları
# BULK_EMAIL_TEST_MODE=0
# Virgülle ayrılmış test alıcıları (test modunda); boşsa JWT/admin e-postası
# BULK_EMAIL_TEST_RECIPIENTS=admin@example.com
# Üretimde zorunlu ikinci onay: istekte confirmPhrase bu metinle aynı olmalı
# BULK_EMAIL_CONFIRM_PHRASE=
# Kullanıcı marketingEmailOptIn=false iken toplu e-posta listesine düşmez; işlemsel e-postalar etkilenmez.

# Redis (BullMQ: API ile worker aynı örneğe bağlanmalı)
# Docker Compose içinde: REDIS_HOST=redis
# API/worker doğrudan makinede çalışıyorsa genelde: REDIS_HOST=127.0.0.1
# REDIS_HOST tanımlıysa BullMQ/önbellek bu host’u kullanır (kök .env’deki REDIS_URL=127.0.0.1 ile çakışmayı önler).
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=
# İsteğe bağlı tek satır (REDIS_HOST yoksa kullanılır): REDIS_URL=redis://127.0.0.1:6379

# Elasticsearch
ELASTICSEARCH_HOST=http://elasticsearch:9200

# MinIO (S3 compatible)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ucuzabak-assets

# SMTP (ör. Mailhog: 1025; gerçek sağlayıcı: 587 + TLS)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="UcuzaBak <noreply@example.com>"

# Mağaza kökü (https://www.ucuzabak.com — canonical www)
STOREFRONT_BASE_URL=http://localhost:3000
# API/worker: NODE_ENV=production ve boşsa e-posta linkleri https://www.ucuzabak.com olur.
# Next (metadata/robots): üretim Docker/K8s vb. için bu değeri mutlaka ayarlayın; Vercel production’da VERCEL_ENV ile de www kullanılır.

# API CORS: credentialed isteklerin Origin’i (üretimde canonical www)
# WEB_ORIGIN=https://www.ucuzabak.com
# veya: CORS_ORIGIN=https://www.ucuzabak.com
# Geçiş döneminde apex’ten doğrudan XHR gerekiyorsa virgülle ekleyin: https://ucuzabak.com

# Refresh cookie’nin www + api alt alanlarında paylaşımı (üretim)
# COOKIE_DOMAIN=.ucuzabak.com
# İsteğe bağlı: sıfırlama jetonu tuzlaması (varsayılan API_JWT_SECRET)
# API_PASSWORD_RESET_PEPPER=
# İsteğe bağlı: e-posta doğrulama jetonu tuzlaması (varsayılan API_PASSWORD_RESET_PEPPER / API_JWT_SECRET)
# API_EMAIL_VERIFICATION_PEPPER=
# Şifre sıfırlama jeton ömrü (saniye, 300–86400; varsayılan 3600 = 1 saat). Worker e-posta metninde aynı değer kullanılır.
PASSWORD_RESET_TOKEN_TTL_SEC=3600
# E-posta doğrulama jeton ömrü (saniye, 3600–604800; varsayılan 172800 = 48 saat)
EMAIL_VERIFICATION_TOKEN_TTL_SEC=172800
# Başarısız giriş koruması (Redis/bellek sayaç; pencere saniye, eşikler)
# LOGIN_FAILURE_WINDOW_SEC=900
# LOGIN_FAILURE_MAX_PER_IP=25
# LOGIN_FAILURE_MAX_PER_EMAIL=8

# API
API_PORT=4000
# Mobil / LAN erişimi için (Nest listen)
LISTEN_HOST=0.0.0.0
API_JWT_ACCESS_TOKEN_TTL=900
API_JWT_REFRESH_TOKEN_TTL=604800
# Zorunlu: API açılışında kontrol edilir (ör. openssl rand -hex 32)
API_JWT_SECRET=
# İsteğe bağlı: yoksa API_JWT_SECRET ile türetilir
# AFFILIATE_IP_SALT=

# prisma db seed — NODE_ENV=production iken demo şifre kullanılmaz; aşağıdakiler zorunlu (min 12 karakter)
# SEED_ADMIN_PASSWORD=
# SEED_USER_PASSWORD=

# Popüler ürünler rayı: affiliate tıklama penceresi (gün, 1–365)
# POPULAR_AFFILIATE_CLICK_WINDOW_DAYS=30

# Liste fiyatı (originalPrice) indirim rozeti: feed tekliflerinde lastSeenAt; yoksa updatedAt bu günden eskiyse vitrin rozeti gösterilmez (varsayılan 21)
# OFFER_LIST_PRICE_FRESH_DAYS=21

# Web (Next.js — tarayıcı + SSR aynı değişken)
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
# Üretim örneği: NEXT_PUBLIC_API_BASE_URL=https://api.ucuzabak.com/api/v1

# Worker
WORKER_NAME=ucuzabak-worker
# Planlı feed: kaç ms’de bir hangi mağazanın sırası geldiği kontrol edilir (varsayılan 60000)
# FEED_SCHEDULER_TICK_MS=60000
# Mağazada feedImportIntervalLabel boşsa kullanılan varsayılan aralık ms (varsayılan 3600000 = 1 saat)
# FEED_IMPORT_INTERVAL_MS=3600000
# Büyük yerel import: satır başı ayrıntılı log (varsayılan kapalı; 1 = aç)
# UCZBK_FEED_IMPORT_TRACE=1
# İlerleme satırı başına feedImport DB güncellemesi aralığı (10–200, varsayılan 50)
# UCZBK_FEED_PROGRESS_FLUSH_EVERY=50
# Toplu importta fiyat alarmı kuyruğunu atla (1/true; yerel yükü düşürür)
# UCZBK_FEED_IMPORT_SKIP_PRICE_ALERTS=1
