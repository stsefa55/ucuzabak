generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  birthDate     DateTime?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  emailVerified Boolean   @default(false)
  /// Pazarlama / toplu e-posta (işlemsel e-postalar bundan etkilenmez).
  marketingEmailOptIn    Boolean   @default(true)
  marketingEmailOptOutAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  favorites     Favorite[]
  priceAlerts   PriceAlert[]
  reviews       Review[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  createdReviews UnmatchedProductReview[] @relation("UnmatchedCreatedBy")
  resolvedReviews UnmatchedProductReview[] @relation("UnmatchedResolvedBy")
  moderatedReviews Review[] @relation("ReviewModeratedBy")
  affiliateClicks AffiliateClick[]
  reviewedStoreProducts StoreProduct[] @relation("StoreProductReviewedBy")
  storeProductMatchAudits StoreProductMatchAuditLog[]

  @@index([role])
  @@index([marketingEmailOptIn, status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String   @unique
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revoked])
}

/// Tek kullanımlık şifre sıfırlama jetonu (ham değer DB’de tutulmaz, yalnızca hash).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// E-posta doğrulama jetonu (ham değer DB’de yok).
model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  parentId  Int?
  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  // Canonical storefront fields (manually managed)
  iconName   String?
  imageUrl   String?
  sortOrder  Int?      // optional because older rows may not have it yet
  isActive   Boolean   @default(true)

  // Backward-compatible fields (existing data / older clients)
  icon      String?
  position  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  products  Product[]
  mappingOverrides CategoryMappingOverride[]

  @@index([parentId])
}

/// Feed kaynağına göre kategori metni → canonical Category eşlemesi (manuel / veri tabanlı).
enum CategoryMatchScope {
  FULL
  LAST_SEGMENT
}

model CategoryMappingOverride {
  id            Int                @id @default(autoincrement())
  /// Kaynak: trendyol, hepsiburada, amazon veya tüm kaynaklar için "*"
  source        String
  matchScope    CategoryMatchScope @default(FULL)
  /// normalizeCategoryPhrase / normalizeCategoryText ile üretilmiş anahtar
  normalizedKey String
  categoryId    Int
  category      Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  confidence    Float              @default(1)
  isManual      Boolean            @default(true)
  rawSourceText String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([source, matchScope, normalizedKey])
  @@index([categoryId])
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  logoUrl   String?
  websiteUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Store {
  id                      Int       @id @default(autoincrement())
  name                    String
  slug                    String    @unique
  logoUrl                 String?
  websiteUrl              String?
  feedUrl                 String?
  feedAuth                String?
  status                  StoreStatus @default(ACTIVE)
  affiliateDefaultTemplate String?
  feedIsActive            Boolean   @default(true)
  feedImportIntervalLabel String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  storeProducts           StoreProduct[]
  offers                  Offer[]
  feedImports             FeedImport[]
  affiliateClicks         AffiliateClick[]
  importSkippedRows       ImportSkippedRow[]
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

/// Mağaza önü (storefront) canonical ürün kaydı. Kimlik: `slug` (benzersiz, boş olmamalı).
/// Teklifler `Offer` üzerinden bağlanır; ham mağaza satırları `StoreProduct` ile tutulur.
model Product {
  id                   Int           @id @default(autoincrement())
  name                 String
  /// Canonical URL: `/urun/[slug]` — sadece küçük harf, rakam ve tire; uygulama katmanında doğrulanır.
  slug                 String        @unique
  description          String?
  brandId              Int?
  brand                Brand?        @relation(fields: [brandId], references: [id])
  categoryId           Int?
  category             Category?     @relation(fields: [categoryId], references: [id])
  mainImageUrl         String?
  specsJson            Json?
  ean                  String?
  modelNumber          String?
  status               ProductStatus @default(ACTIVE)
  lowestPriceCache     Decimal?      @db.Decimal(12, 2)
  lowestPriceStoreId   Int?
  offerCountCache      Int           @default(0)
  lastPriceUpdatedAt   DateTime?
  ratingAvg            Float         @default(0)
  ratingCount          Int           @default(0)
  /// Ana sayfa «Öne çıkan» rayı — yalnızca admin işaretler; tıklama/teklif sayısından bağımsız.
  isFeatured           Boolean       @default(false)
  /// Vitrinte sıra (küçük önce). Yalnızca isFeatured=true iken anlamlı.
  featuredSortOrder    Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  offers               Offer[]
  storeProducts        StoreProduct[]
  productImages        ProductImage[]
  priceAlerts          PriceAlert[]
  favorites            Favorite[]
  reviews              Review[]
  affiliateClicks      AffiliateClick[]
  unmatchedProductReviews UnmatchedProductReview[]

  @@index([brandId])
  @@index([categoryId])
  @@index([status, categoryId])
  @@index([status, brandId])
  @@index([status, lowestPriceCache])
  @@index([ean])
  @@index([modelNumber])
  @@index([isFeatured, featuredSortOrder])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  position  Int     @default(0)

  @@index([productId])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

/// Mağaza / feed kaynaklı ham ürün satırı; storefront’ta doğrudan gösterilmez, `Product` ile eşlenir.
model StoreProduct {
  id               Int        @id @default(autoincrement())
  storeId          Int
  store            Store      @relation(fields: [storeId], references: [id])
  externalId       String
  productId        Int?
  product          Product?   @relation(fields: [productId], references: [id])
  title            String
  ean              String?
  modelNumber      String?
  specsJson        Json?
  url              String
  imageUrl         String?
  matchStatus      MatchStatus @default(UNMATCHED)
  matchScore       Int         @default(0)
  matchDetailsJson Json?
  reviewFlag       StoreProductReviewFlag @default(NONE)
  reviewNotes      String?
  reviewedAt       DateTime?
  reviewedByUserId Int?
  reviewedBy       User?       @relation("StoreProductReviewedBy", fields: [reviewedByUserId], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  offers           Offer[]
  unmatchedReviews UnmatchedProductReview[]
  matchAuditLogs   StoreProductMatchAuditLog[]

  @@unique([storeId, externalId])
  @@index([storeId])
  @@index([productId])
  @@index([matchStatus, matchScore])
  @@index([ean])
  @@index([modelNumber])
  @@index([reviewFlag])
}

enum MatchStatus {
  UNMATCHED
  AUTO_MATCHED
  MANUAL_MATCHED
  REJECTED
}

enum StoreProductMatchAuditAction {
  MANUAL_ASSIGN_PRODUCT
  CREATE_CANONICAL_PRODUCT
}

/// Admin panelinden manuel ürün eşlemesi / yeni canonical oluşturma denetim izi.
model StoreProductMatchAuditLog {
  id                  Int                         @id @default(autoincrement())
  action              StoreProductMatchAuditAction
  storeProductId      Int
  storeProduct        StoreProduct                @relation(fields: [storeProductId], references: [id], onDelete: Restrict)
  actorUserId         Int
  actor               User                        @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  previousProductId   Int?
  newProductId        Int?
  metadataJson        Json?
  createdAt           DateTime                    @default(now())

  @@index([storeProductId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
}

/// Operasyon: mağaza satırı inceleme bayrağı (storefront’u etkilemez).
enum StoreProductReviewFlag {
  NONE
  FLAGGED
  REVIEWED
  IGNORED
}

/// Import sırasında DB’ye hiç yazılamayan satırlar (ör. çözülemeyen kategori) — operasyon listesi için.
model ImportSkippedRow {
  id                       Int      @id @default(autoincrement())
  storeId                  Int
  store                    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  externalId               String?
  feedSource               String?
  categoryText             String?
  normalizedCategoryKey    String?
  title                    String?
  brand                    String?
  reason                   String
  categoryResolutionMethod String?
  rawPayload               Json?
  createdAt                DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([reason])
  @@index([feedSource])
}

/// Belirli bir mağaza teklifi; her zaman bir `Product` ve bir `StoreProduct` ile ilişkilidir.
model Offer {
  id              Int       @id @default(autoincrement())
  productId       Int
  product         Product   @relation(fields: [productId], references: [id])
  storeId         Int
  store           Store     @relation(fields: [storeId], references: [id])
  storeProductId  Int
  storeProduct    StoreProduct @relation(fields: [storeProductId], references: [id])
  currentPrice    Decimal   @db.Decimal(12, 2)
  originalPrice   Decimal?  @db.Decimal(12, 2)
  currency        String    @default("TRY")
  inStock         Boolean   @default(true)
  stockQuantity   Int?
  deliveryInfo    String?
  shippingCost    Decimal?  @db.Decimal(12, 2)
  affiliateUrl    String?
  affiliateCampaign String?
  status          OfferStatus @default(ACTIVE)
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  priceHistory    PriceHistory[]
  affiliateClicks AffiliateClick[]

  @@index([productId, currentPrice])
  @@index([storeId, productId])
  @@index([storeProductId])
}

enum OfferStatus {
  ACTIVE
  DISABLED
  OUT_OF_STOCK
}

model PriceHistory {
  id          Int      @id @default(autoincrement())
  offerId     Int
  offer       Offer    @relation(fields: [offerId], references: [id])
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("TRY")
  inStock     Boolean  @default(true)
  recordedAt  DateTime @default(now())

  @@index([offerId, recordedAt])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model PriceAlert {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User    @relation(fields: [userId], references: [id])
  productId         Int
  product           Product @relation(fields: [productId], references: [id])
  targetPrice       Decimal @db.Decimal(12, 2)
  currency          String  @default("TRY")
  isActive          Boolean @default(true)
  lastTriggeredAt   DateTime?
  lastNotifiedPrice Decimal? @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([productId, targetPrice, isActive])
}

model Review {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  rating       Int
  title        String?
  body         String
  status       ReviewStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  moderatedAt  DateTime?
  moderatedBy  Int?
  createdByUser User?      @relation("ReviewModeratedBy", fields: [moderatedBy], references: [id])

  @@index([productId, status])
  @@index([userId])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model AffiliateClick {
  id         Int      @id @default(autoincrement())
  offerId    Int
  offer      Offer    @relation(fields: [offerId], references: [id])
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  storeId    Int
  store      Store    @relation(fields: [storeId], references: [id])
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  ipHash     String
  userAgent  String?
  referer    String?
  createdAt  DateTime @default(now())

  @@index([offerId, createdAt])
  @@index([storeId, createdAt])
  @@index([productId, createdAt])
}

model FeedImport {
  id           Int        @id @default(autoincrement())
  storeId      Int
  store        Store      @relation(fields: [storeId], references: [id])
  type         FeedType
  status       FeedStatus @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  /// Parse sonrası satır sayısı (ilerleme için; RUNNING iken artar)
  totalItems   Int?
  processedCount Int      @default(0)
  createdCount Int       @default(0)
  updatedCount Int       @default(0)
  matchedCount   Int      @default(0)
  unmatchedCount Int      @default(0)
  errorCount   Int       @default(0)
  errorLog     String?
  /// Worker: işlenen satır özeti, reasonCounts, örnek loglar (JSON)
  importSummaryJson Json?
  sourceRef    String?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([storeId, createdAt])
  @@index([status])
}

enum FeedType {
  XML
  CSV
  JSON_API
}

enum FeedStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

model UnmatchedProductReview {
  id                 Int          @id @default(autoincrement())
  storeProductId     Int
  storeProduct       StoreProduct @relation(fields: [storeProductId], references: [id])
  suggestedProductId Int?
  suggestedProduct   Product?     @relation(fields: [suggestedProductId], references: [id])
  status             UnmatchedStatus @default(PENDING)
  notes              String?
  createdById        Int?
  createdBy          User?        @relation("UnmatchedCreatedBy", fields: [createdById], references: [id])
  resolvedById       Int?
  resolvedBy         User?        @relation("UnmatchedResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt         DateTime?
  createdAt          DateTime     @default(now())

  @@index([status, createdAt])
  @@index([storeProductId])
}

enum UnmatchedStatus {
  PENDING
  APPROVED
  REJECTED
}

model Banner {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  linkUrl   String?
  title     String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchQueryStat {
  id        Int      @id @default(autoincrement())
  query     String   @unique
  count     Int      @default(1)
  updatedAt DateTime @updatedAt

  @@index([count])
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

/// Worker SMTP gönderimleri: başarı / hata + isteğe bağlı yeniden kuyruklama verisi.
model EmailDeliveryLog {
  id           Int                 @id @default(autoincrement())
  jobName      String
  toEmail      String
  subject      String              @db.VarChar(500)
  status       EmailDeliveryStatus
  errorText    String?
  bullJobId    String?             @db.VarChar(128)
  retryPayload Json?
  createdAt    DateTime            @default(now())

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([jobName])
}

/// psql restore denemeleri (başarılı / başarısız); geri yüklemeden önce alınan otomatik snapshot dosya adı.
model BackupRestoreLog {
  id                     Int      @id @default(autoincrement())
  targetBackupFile       String
  preRestoreSnapshotFile String?
  initiatedByUserId      Int?
  success                Boolean
  errorText              String?
  createdAt              DateTime @default(now())

  @@index([createdAt])
}

/// UTC günü başına kuyruğa eklenen toplu e-posta alıcı sayısı (günlük üst sınır için).
model BulkEmailQuotaDay {
  day         DateTime @id @db.Date
  queuedCount Int      @default(0)
}

