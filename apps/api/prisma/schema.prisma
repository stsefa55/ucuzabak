generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  birthDate     DateTime?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  favorites     Favorite[]
  priceAlerts   PriceAlert[]
  reviews       Review[]
  refreshTokens RefreshToken[]
  createdReviews UnmatchedProductReview[] @relation("UnmatchedCreatedBy")
  resolvedReviews UnmatchedProductReview[] @relation("UnmatchedResolvedBy")
  moderatedReviews Review[] @relation("ReviewModeratedBy")
  affiliateClicks AffiliateClick[]

  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String   @unique
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revoked])
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  parentId  Int?
  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  // Canonical storefront fields (manually managed)
  iconName   String?
  imageUrl   String?
  sortOrder  Int?      // optional because older rows may not have it yet
  isActive   Boolean   @default(true)

  // Backward-compatible fields (existing data / older clients)
  icon      String?
  position  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  products  Product[]

  @@index([parentId])
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  logoUrl   String?
  websiteUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Store {
  id                      Int       @id @default(autoincrement())
  name                    String
  slug                    String    @unique
  logoUrl                 String?
  websiteUrl              String?
  feedUrl                 String?
  feedAuth                String?
  status                  StoreStatus @default(ACTIVE)
  affiliateDefaultTemplate String?
  feedIsActive            Boolean   @default(true)
  feedImportIntervalLabel String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  storeProducts           StoreProduct[]
  offers                  Offer[]
  feedImports             FeedImport[]
  affiliateClicks         AffiliateClick[]
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id                   Int           @id @default(autoincrement())
  name                 String
  slug                 String        @unique
  description          String?
  brandId              Int?
  brand                Brand?        @relation(fields: [brandId], references: [id])
  categoryId           Int?
  category             Category?     @relation(fields: [categoryId], references: [id])
  mainImageUrl         String?
  specsJson            Json?
  ean                  String?
  modelNumber          String?
  status               ProductStatus @default(ACTIVE)
  lowestPriceCache     Decimal?      @db.Decimal(12, 2)
  lowestPriceStoreId   Int?
  offerCountCache      Int           @default(0)
  lastPriceUpdatedAt   DateTime?
  ratingAvg            Float         @default(0)
  ratingCount          Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  offers               Offer[]
  storeProducts        StoreProduct[]
  productImages        ProductImage[]
  priceAlerts          PriceAlert[]
  favorites            Favorite[]
  reviews              Review[]
  affiliateClicks      AffiliateClick[]
  unmatchedProductReviews UnmatchedProductReview[]

  @@index([brandId])
  @@index([categoryId])
  @@index([ean])
  @@index([modelNumber])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  position  Int     @default(0)

  @@index([productId])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model StoreProduct {
  id               Int        @id @default(autoincrement())
  storeId          Int
  store            Store      @relation(fields: [storeId], references: [id])
  externalId       String
  productId        Int?
  product          Product?   @relation(fields: [productId], references: [id])
  title            String
  ean              String?
  modelNumber      String?
  specsJson        Json?
  url              String
  imageUrl         String?
  matchStatus      MatchStatus @default(UNMATCHED)
  matchScore       Int         @default(0)
  matchDetailsJson Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  offers           Offer[]
  unmatchedReviews UnmatchedProductReview[]

  @@unique([storeId, externalId])
  @@index([storeId])
  @@index([productId])
  @@index([matchStatus, matchScore])
  @@index([ean])
  @@index([modelNumber])
}

enum MatchStatus {
  UNMATCHED
  AUTO_MATCHED
  MANUAL_MATCHED
  REJECTED
}

model Offer {
  id              Int       @id @default(autoincrement())
  productId       Int
  product         Product   @relation(fields: [productId], references: [id])
  storeId         Int
  store           Store     @relation(fields: [storeId], references: [id])
  storeProductId  Int
  storeProduct    StoreProduct @relation(fields: [storeProductId], references: [id])
  currentPrice    Decimal   @db.Decimal(12, 2)
  originalPrice   Decimal?  @db.Decimal(12, 2)
  currency        String    @default("TRY")
  inStock         Boolean   @default(true)
  stockQuantity   Int?
  deliveryInfo    String?
  shippingCost    Decimal?  @db.Decimal(12, 2)
  affiliateUrl    String?
  affiliateCampaign String?
  status          OfferStatus @default(ACTIVE)
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  priceHistory    PriceHistory[]
  affiliateClicks AffiliateClick[]

  @@index([productId, currentPrice])
  @@index([storeId, productId])
  @@index([storeProductId])
}

enum OfferStatus {
  ACTIVE
  DISABLED
  OUT_OF_STOCK
}

model PriceHistory {
  id          Int      @id @default(autoincrement())
  offerId     Int
  offer       Offer    @relation(fields: [offerId], references: [id])
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("TRY")
  inStock     Boolean  @default(true)
  recordedAt  DateTime @default(now())

  @@index([offerId, recordedAt])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model PriceAlert {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User    @relation(fields: [userId], references: [id])
  productId         Int
  product           Product @relation(fields: [productId], references: [id])
  targetPrice       Decimal @db.Decimal(12, 2)
  currency          String  @default("TRY")
  isActive          Boolean @default(true)
  lastTriggeredAt   DateTime?
  lastNotifiedPrice Decimal? @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([productId, targetPrice, isActive])
}

model Review {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  rating       Int
  title        String?
  body         String
  status       ReviewStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  moderatedAt  DateTime?
  moderatedBy  Int?
  createdByUser User?      @relation("ReviewModeratedBy", fields: [moderatedBy], references: [id])

  @@index([productId, status])
  @@index([userId])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model AffiliateClick {
  id         Int      @id @default(autoincrement())
  offerId    Int
  offer      Offer    @relation(fields: [offerId], references: [id])
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  storeId    Int
  store      Store    @relation(fields: [storeId], references: [id])
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  ipHash     String
  userAgent  String?
  referer    String?
  createdAt  DateTime @default(now())

  @@index([offerId, createdAt])
  @@index([storeId, createdAt])
  @@index([productId, createdAt])
}

model FeedImport {
  id           Int        @id @default(autoincrement())
  storeId      Int
  store        Store      @relation(fields: [storeId], references: [id])
  type         FeedType
  status       FeedStatus @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  processedCount Int      @default(0)
  createdCount Int       @default(0)
  updatedCount Int       @default(0)
  errorCount   Int       @default(0)
  errorLog     String?
  sourceRef    String?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([storeId, createdAt])
  @@index([status])
}

enum FeedType {
  XML
  CSV
  JSON_API
}

enum FeedStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

model UnmatchedProductReview {
  id                 Int          @id @default(autoincrement())
  storeProductId     Int
  storeProduct       StoreProduct @relation(fields: [storeProductId], references: [id])
  suggestedProductId Int?
  suggestedProduct   Product?     @relation(fields: [suggestedProductId], references: [id])
  status             UnmatchedStatus @default(PENDING)
  notes              String?
  createdById        Int?
  createdBy          User?        @relation("UnmatchedCreatedBy", fields: [createdById], references: [id])
  resolvedById       Int?
  resolvedBy         User?        @relation("UnmatchedResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt         DateTime?
  createdAt          DateTime     @default(now())

  @@index([status, createdAt])
  @@index([storeProductId])
}

enum UnmatchedStatus {
  PENDING
  APPROVED
  REJECTED
}

model Banner {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  linkUrl   String?
  title     String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchQueryStat {
  id        Int      @id @default(autoincrement())
  query     String   @unique
  count     Int      @default(1)
  updatedAt DateTime @updatedAt

  @@index([count])
}

