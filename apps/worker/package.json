{
  "name": "@ucuzabak/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "seed:feeds": "ts-node src/enqueue-sample-feeds.ts",
    "import:normalized-json": "ts-node src/import-normalized-json.ts",
    "test:category-map": "ts-node --transpile-only scripts/test-category-mapping.ts",
    "analyze:category-feed": "ts-node --transpile-only scripts/analyze-category-feed.ts",
    "audit:product-matching": "ts-node --transpile-only scripts/audit-product-matching.ts",
    "bootstrap:category-overrides": "ts-node --transpile-only scripts/bootstrap-category-overrides-from-feed.ts",
    "extract:brands-pending": "ts-node --transpile-only scripts/extract-brands-from-pending-json.ts"
  },
  "dependencies": {
    "@ucuzabak/shared": "workspace:*",
    "bullmq": "^5.6.0",
    "fast-xml-parser": "^4.5.0",
    "ioredis": "^5.4.1",
    "string-similarity": "^4.0.4",
    "@prisma/client": "^5.20.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.17",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
